generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(TECNICO)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  maintenanceRecords MaintenanceRecord[]
  reports      ServiceReport[]
  assignedTickets Ticket[] @relation("AssignedTechnician")
  activityLogs ActivityLog[]
  @@map("users")
}

enum UserRole {
  ADMIN
  TECNICO
}

model Client {
  id           String       @id @default(uuid())
  businessName String       @map("business_name")
  nit          String?      @unique
  address      String?
  branch       String?
  city         String?
  phone        String?
  contactName  String?      @map("contact_name")
  email        String?
  logoUrl      String?      @map("logo_url")
  status       ClientStatus @default(ACTIVO)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  assets       Asset[]
  reports      ServiceReport[]
  tickets      Ticket[]
  alerts       Alert[]
  @@map("clients")
}

enum ClientStatus {
  ACTIVO
  INACTIVO
}

model AssetType {
  id          String   @id @default(uuid())
  name        String
  icon        String   @default("box")
  fieldSchema Json     @default("[]") @map("field_schema")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  assets      Asset[]
  @@map("asset_types")
}

model Asset {
  id              String      @id @default(uuid())
  clientId        String      @map("client_id")
  assetTypeId     String      @map("asset_type_id")
  code            String?     @unique
  name            String
  brand           String?
  model           String?
  serial          String?
  purchaseDate    DateTime?   @map("purchase_date")
  warrantyUntil   DateTime?   @map("warranty_until")
  supplier        String?
  assignedUser    String?     @map("assigned_user")
  responsible     String?
  passwordEnc     String?     @map("password_enc")
  remoteAccess    String?     @map("remote_access")
  ipAddress       String?     @map("ip_address")
  macAddress      String?     @map("mac_address")
  location        String?
  status          AssetStatus @default(ACTIVO)
  dynFields       Json        @default("{}") @map("dyn_fields")
  extraFields     Json        @default("[]") @map("extra_fields")
  nextMaintenance DateTime?   @map("next_maintenance")
  qrCodeUrl       String?     @map("qr_code_url")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assetType       AssetType   @relation(fields: [assetTypeId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  attachments     Attachment[]
  reportAssets    ReportAsset[]
  tickets         Ticket[]
  alerts          Alert[]
  @@index([clientId])
  @@map("assets")
}

enum AssetStatus {
  ACTIVO
  EN_MANTENIMIENTO
  DADO_DE_BAJA
}

model MaintenanceRecord {
  id           String          @id @default(uuid())
  assetId      String          @map("asset_id")
  technicianId String?         @map("technician_id")
  date         DateTime
  type         MaintenanceType
  description  String
  timeSpent    Float?          @map("time_spent_hours")
  nextMaint    DateTime?       @map("next_maintenance")
  createdAt    DateTime        @default(now()) @map("created_at")
  asset        Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  technician   User?           @relation(fields: [technicianId], references: [id])
  @@index([assetId])
  @@map("maintenance_records")
}

enum MaintenanceType {
  PREVENTIVO
  CORRECTIVO
}

model Attachment {
  id           String         @id @default(uuid())
  entityType   AttachmentType @map("entity_type")
  entityId     String         @map("entity_id")
  fileName     String         @map("file_name")
  fileUrl      String         @map("file_url")
  fileType     String?        @map("file_type")
  fileSize     Int?           @map("file_size")
  uploadedById String?        @map("uploaded_by")
  createdAt    DateTime       @default(now()) @map("created_at")
  @@index([entityType, entityId])
  @@map("attachments")
}

enum AttachmentType {
  ASSET
  MAINTENANCE
  REPORT
  TICKET
}

model ServiceReport {
  id           String      @id @default(uuid())
  reportNumber String      @unique @map("report_number")
  clientId     String      @map("client_id")
  technicianId String?     @map("technician_id")
  date         DateTime
  serviceType  ServiceType @map("service_type")
  description  String
  observations String?
  timeUsed     Float?      @map("time_used_hours")
  signatureUrl String?     @map("signature_url")
  pdfUrl       String?     @map("pdf_url")
  sentAt       DateTime?   @map("sent_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  client       Client      @relation(fields: [clientId], references: [id])
  technician   User?       @relation(fields: [technicianId], references: [id])
  assets       ReportAsset[]
  @@index([clientId])
  @@map("service_reports")
}

model ReportAsset {
  reportId String        @map("report_id")
  assetId  String        @map("asset_id")
  report   ServiceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  asset    Asset         @relation(fields: [assetId], references: [id])
  @@id([reportId, assetId])
  @@map("report_assets")
}

enum ServiceType {
  EN_SITIO
  REMOTO
  TELEFONICO
}

model Ticket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique @map("ticket_number")
  clientId     String       @map("client_id")
  assetId      String?      @map("asset_id")
  assignedToId String?      @map("assigned_to")
  title        String
  description  String?
  priority     Priority     @default(MEDIA)
  status       TicketStatus @default(ABIERTO)
  slaHours     Int?         @map("sla_hours")
  resolvedAt   DateTime?    @map("resolved_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  client       Client       @relation(fields: [clientId], references: [id])
  asset        Asset?       @relation(fields: [assetId], references: [id])
  assignedTo   User?        @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  @@index([clientId])
  @@map("tickets")
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum TicketStatus {
  ABIERTO
  EN_PROCESO
  CERRADO
}

model Alert {
  id        String    @id @default(uuid())
  clientId  String?   @map("client_id")
  assetId   String?   @map("asset_id")
  type      AlertType
  message   String
  dueDate   DateTime? @map("due_date")
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  client    Client?   @relation(fields: [clientId], references: [id])
  asset     Asset?    @relation(fields: [assetId], references: [id])
  @@map("alerts")
}

enum AlertType {
  GARANTIA
  MANTENIMIENTO
  TICKET
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])
  @@map("activity_logs")
}
